<?xml version="1.0" encoding="UTF-8"?>
<!--
  Fleet headless supervisor pass — launchd template (Tier 1 leader continuity).

  Install (per project):
    1. Copy to ~/Library/LaunchAgents/com.fleet.supervisor.<PROJECT>.plist
    2. Replace __PROJECT_ROOT__ with the absolute project path and <PROJECT>
       in the Label with a unique name.
    3. launchctl load ~/Library/LaunchAgents/com.fleet.supervisor.<PROJECT>.plist
    Remove: launchctl unload ... && rm the plist.

  Runs ./.fleet/supervisor_pass.sh every 25 minutes. The pass picks its model
  from the leader ladder (capacity registry) and exits 75 on a quota hit; the
  caretaker keeps workers fed between successful passes. Stagger StartInterval
  across projects (1500/1800/2100) so multiple leaders don't wake together.

  For a machine-reboot-proof WATCHER stack, a similar plist can run
  ./.fleet/start.sh at load with RunAtLoad=true (start.sh is idempotent).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.fleet.supervisor.__PROJECT_NAME__</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__PROJECT_ROOT__/.fleet/supervisor_pass.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__PROJECT_ROOT__</string>
  <key>StartInterval</key>
  <integer>1500</integer>
  <key>RunAtLoad</key>
  <false/>
  <key>StandardOutPath</key>
  <string>__PROJECT_ROOT__/.fleet/status/logs/supervisor-launchd.log</string>
  <key>StandardErrorPath</key>
  <string>__PROJECT_ROOT__/.fleet/status/logs/supervisor-launchd.log</string>
</dict>
</plist>
